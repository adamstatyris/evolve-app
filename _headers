# Cloudflare Pages headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Service worker must always revalidate so users never get stuck on a stale SW.
/sw.js
  Cache-Control: no-cache
  Service-Worker-Allowed: /

# Manifest is small and tied to app identity; revalidate often.
/manifest.webmanifest
  Cache-Control: public, max-age=300

# Icons rarely change; allow longer browser cache.
/icons/*
  Cache-Control: public, max-age=86400

# HTML entry: short cache so app updates reach users quickly.
/
  Cache-Control: public, max-age=300
/index.html
  Cache-Control: public, max-age=300
